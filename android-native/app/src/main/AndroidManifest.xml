<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!--
      下载目录写到 /sdcard/Download/MusicDL:
      - API ≤ 28:需要 WRITE_EXTERNAL_STORAGE 运行时权限
      - API 29(Q):Scoped Storage 启用,但 Download/ 仍可直接写;requestLegacyExternalStorage=true 让旧路径继续工作
      - API ≥ 30(R+):/sdcard/Download/ 在 Scoped Storage 下对所有 app 公开可写,无需权限
    -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <application
        android:name=".MusicDlApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@style/Theme.MusicDLCar"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|uiMode"
            android:theme="@style/Theme.MusicDLCar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.APP_MUSIC" />
            </intent-filter>
            <!-- 允许通过标准音乐播放器意图启动 -->
            <intent-filter>
                <action android:name="android.intent.action.MUSIC_PLAYER" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.APP_MUSIC" />
            </intent-filter>
            <!-- 允许通过系统媒体搜索并播放意图启动 -->
            <intent-filter>
                <action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- 允许通过网易云音乐的 URL Scheme 唤起播放 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="orpheus" />
                <data android:scheme="orpheuswidget" />
            </intent-filter>
        </activity>

        <service
            android:name=".playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

        <service
            android:name=".playback.CMApiService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.netease.cloudmusic.third.api.CMApiService" />
            </intent-filter>
        </service>

        <!-- 声明媒体按钮接收器，允许系统通过硬件按钮或语音指令（如播放/暂停）在后台或被杀死时唤醒并控制应用 -->
        <receiver
            android:name="androidx.media3.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>
        <!-- Baidu DuerOS, Geely ECARX, CMCC, and standard voice launch handler -->
        <activity
            android:name="com.netease.cloudmusic.audio.launch.IotRedirectActivity"
            android:theme="@style/Theme.MusicDLCar"
            android:launchMode="singleInstance"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="dueros/audio" android:scheme="dueros" android:host="netease.audioplayer" android:path="/player" />
                <data android:mimeType="cmcc/audio" android:scheme="cmcc" android:host="netease.audioplayer" android:path="/player" />
                <data android:mimeType="voice/audio" android:scheme="voice" android:host="netease.audioplayer" android:path="/player" />
                <data android:mimeType="voice/audio" android:scheme="voice" android:host="netease.audioplayer" android:path="/player/v2" />
            </intent-filter>
            <intent-filter>
                <action android:name="ecarx.intent.action.ECARX_VR_APP_OPEN" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="ecarx" android:host="vr.com" android:path="/网易云音乐" />
            </intent-filter>
        </activity>

        <!-- BYD voice control broadcast receiver -->
        <receiver
            android:name="com.netease.cloudmusic.iot.byd.broadcast.BydControlBroadcastReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.byd.action.FUNCTION_UPDATE_RESULT" />
                <action android:name="byd.intent.action.MEDIA_BUTTON" />
                <action android:name="byd.intent.action.MEDIA_MODE" />
                <action android:name="com.byd.action.AUTOVOICE_SEARCH_PLUS" />
                <action android:name="com.byd.action.AUTOVOICE_SEARCH" />
                <action android:name="com.byd.action.AUTOVOICE_COLLECT" />
                <action android:name="com.byd.action.AUTOVOICE_UNCOLLECT" />
                <action android:name="com.byd.action.AUTOVOICE_REWIND" />
                <action android:name="com.byd.action.AUTOVOICE_FORWARD" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_MODE" />
                <action android:name="com.byd.action.AUTOVOICE_OPEN_LIST" />
                <action android:name="com.byd.action.AUTOVOICE_CLOSE_LIST" />
                <action android:name="com.byd.action.AUTOVOICE_QUIT" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_LIKE" />
                <action android:name="com.byd.action.AUTOVOICE_RECOMMEND" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_FAVORITE" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_SONG_SHEET" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_LATELY" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_RANDOM" />
                <action android:name="com.byd.action.AUTOVOICE_BOOK" />
                <action android:name="com.byd.action.AUTOVOICE_UNBOOK" />
                <action android:name="com.byd.action.AUTOVOICE_OPEN_LYRIC" />
                <action android:name="com.byd.action.AUTOVOICE_CLOSE_LYRIC" />
                <action android:name="com.byd.action.AUTOVOICE_JUMP_TO" />
                <action android:name="com.byd.action.AUTOVOICE_FULL_SCREEN" />
                <action android:name="com.byd.action.AUTOVOICE_UNFULL_SCREEN" />
                <action android:name="com.byd.action.AUTOVOICE_SPEED_ADJUST" />
                <action android:name="com.byd.action.AUTOVOICE_SKIP_TITLE" />
                <action android:name="com.byd.action.AUTOVOICE_SKIP_END" />
                <action android:name="com.byd.action.AUTOVOICE_DOWNLOAD" />
                <action android:name="com.byd.action.AUTOVOICE_UNDOWNLOAD" />
                <action android:name="com.byd.action.AUTOVOICE_DEFINITION_SET" />
                <action android:name="com.byd.action.AUTOVOICE_QUALITY" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_BOOK" />
                <action android:name="com.byd.action.AUTOVOICE_PLAY_DOWNLOAD" />
            </intent-filter>
        </receiver>

        <!-- 声明为车载/汽车多媒体应用 -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />
        <meta-data
            android:name="android.car.application"
            android:resource="@xml/automotive_app_desc" />
    </application>
</manifest>
